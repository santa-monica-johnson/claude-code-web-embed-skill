# Local Agent listen host (loopback strongly recommended)
CLAUDE_AGENT_HOST=127.0.0.1
CLAUDE_AGENT_PORT=4820

# Working directory to launch Claude Code in (defaults to the agent's cwd)
CLAUDE_AGENT_CWD=

# Allowed origins (comma-separated). If unset, only localhost-family origins are allowed.
# e.g. https://your-name.github.io,http://localhost:5173
# To allow opening the frontend directly as a local file (file:///path/to/index.html),
# add the literal string "null" (that's the Origin a browser sends for file:// pages) —
# and re-list any http://localhost:PORT origins you still need, since setting this at
# all disables the automatic "localhost family" allowance. e.g.:
#   CLAUDE_AGENT_ALLOWED_ORIGINS=null,http://localhost:8000
CLAUDE_AGENT_ALLOWED_ORIGINS=

# Session token (if unset, one is randomly generated per start and shown in the startup log)
CLAUDE_AGENT_TOKEN=

# Claude Code launch command and arguments
CLAUDE_AGENT_COMMAND=claude
CLAUDE_AGENT_ARGS=

# Max concurrent sessions
CLAUDE_AGENT_MAX_SESSIONS=4
