# Local Agent の待ち受けホスト（localhost 固定を強く推奨）
CLAUDE_AGENT_HOST=127.0.0.1
CLAUDE_AGENT_PORT=4820

# Claude Code を起動する作業ディレクトリ（未指定ならエージェントの cwd）
CLAUDE_AGENT_CWD=

# 許可する Origin（カンマ区切り）。未指定なら localhost 系のみ許可。
# 例: https://your-name.github.io,http://localhost:5173
CLAUDE_AGENT_ALLOWED_ORIGINS=

# セッショントークン（未指定なら起動ごとにランダム生成し、起動ログに表示）
CLAUDE_AGENT_TOKEN=

# Claude Code の起動コマンドと引数
CLAUDE_AGENT_COMMAND=claude
CLAUDE_AGENT_ARGS=

# 同時セッション上限
CLAUDE_AGENT_MAX_SESSIONS=4
